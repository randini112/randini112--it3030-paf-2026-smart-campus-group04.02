Mode(!darkMode);\r\n\r\n  return (\r\n    <ThemeContext.Provider value={{ darkMode, toggleTheme }}>\r\n      {children}\r\n    </ThemeContext.Provider>\r\n  );\r\n};\r\n\r\nexport const useTheme = () => useContext(ThemeContext);"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,aAAa,CAAEC,QAAQ,CAAEC,SAAS,CAAEC,UAAU,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAE9E,KAAM,CAAAC,YAAY,cAAGN,aAAa,CAAC,CAAC,CAEpC,MAAO,MAAM,CAAAO,aAAa,CAAGC,IAAA,EAAkB,IAAjB,CAAEC,QAAS,CAAC,CAAAD,IAAA,CACxC,KAAM,CAACE,QAAQ,CAAEC,WAAW,CAAC,CAAGV,QAAQ,CAAC,IAAM,CAC7C,KAAM,CAAAW,KAAK,CAAGC,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,CAC3C,MAAO,CAAAF,KAAK,GAAK,MAAM,CACzB,CAAC,CAAC,CAEFV,SAAS,CAAC,IAAM,CACd,GAAIQ,QAAQ,CAAE,CACZK,QAAQ,CAACC,IAAI,CAACC,KAAK,CAACC,UAAU,CAAG,SAAS,CAC1CH,QAAQ,CAACC,IAAI,CAACC,KAAK,CAACE,KAAK,CAAG,SAAS,CACrCN,YAAY,CAACO,OAAO,CAAC,OAAO,CAAE,MAAM,CAAC,CACvC,CAAC,IAAM,CACLL,QAAQ,CAACC,IAAI,CAACC,KAAK,CAACC,UAAU,CAAG,SAAS,CAC1CH,QAAQ,CAACC,IAAI,CAACC,KAAK,CAACE,KAAK,CAAG,SAAS,CACrCN,YAAY,CAACO,OAAO,CAAC,OAAO,CAAE,OAAO,CAAC,CACxC,CACF,CAAC,CAAE,CAACV,QAAQ,CAAC,CAAC,CAEd,KAAM,CAAAW,WAAW,CAAGA,CAAA,GAAMV,WAAW,CAAC,CAACD,QAAQ,CAAC,CAEhD,mBACEL,IAAA,CAACC,YAAY,CAACgB,QAAQ,EAACC,KAAK,CAAE,CAAEb,QAAQ,CAAEW,WAAY,CAAE,CAAAZ,QAAA,CACrDA,QAAQ,CACY,CAAC,CAE5B,CAAC,CAED,MAAO,MAAM,CAAAe,QAAQ,CAAGA,CAAA,GAAMrB,UAAU,CAACG,YAAY,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}